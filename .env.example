# Copy this to .env.local and fill in your keys for local dev.
# In production, set these in the Vercel dashboard (Settings → Environment Variables).

# ── Azure OpenAI ──────────────────────────────────────────────────────────
# Your Azure OpenAI resource key.
AZURE_OPENAI_API_KEY=your-azure-key-here

# Your Azure OpenAI endpoint — the base URL, WITHOUT the trailing /openai.
# Example: https://genaitraining-aoai2.openai.azure.com
AZURE_OPENAI_ENDPOINT=https://genaitraining-aoai2.openai.azure.com

# The deployment name from your Azure OpenAI resource (NOT the model family name).
# Defaults to gpt-4.1 if unset.
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# Optional: pin a specific API version. Defaults to 2025-03-01-preview.
# AZURE_OPENAI_API_VERSION=2025-03-01-preview

# ── App access ────────────────────────────────────────────────────────────
# The password for the login page. Required.
# This protects both the UI and every /api/* endpoint.
APP_PASSWORD=ONYX22JUN2026
